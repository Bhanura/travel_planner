# LLM configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Application logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL
LOG_LEVEL=INFO

# Provider base URLs used by the MCP servers
HOTEL_PROVIDER_BASE_URL=https://standing-fish-574.convex.site/hotels
FLIGHT_PROVIDER_BASE_URL=https://standing-fish-574.convex.site/flights

# Backend API URL used by the Gradio frontend
TRAVEL_PLANNER_API_URL=http://127.0.0.1:8000

# Required comma-separated explicit frontend origins; wildcard '*' is rejected
ALLOWED_ORIGINS=http://127.0.0.1:7860,http://localhost:7860
